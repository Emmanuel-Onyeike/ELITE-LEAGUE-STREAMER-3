<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ELITE LEAGUE | Live Finals</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/Styles.css"> <!-- Keep if you have custom CSS; otherwise remove -->
    <script src="https://download.agora.io/sdk/release/AgoraRTC_N-4.18.0.js"></script>
</head>
<body class="bg-[#050505] text-white font-sans antialiased overflow-x-hidden">

    <header class="p-6 flex justify-between items-center border-b border-white/10 bg-black/50 backdrop-blur-md sticky top-0 z-40">
        <div class="flex items-center space-x-3">
            <div id="statusIndicator" class="w-3 h-3 bg-gray-600 rounded-full shadow-[0_0_10px_rgba(75,85,99,0.5)]"></div>
            <h1 class="text-2xl font-black tracking-tighter uppercase italic">
                Elite <span class="text-amber-500">League</span>
            </h1>
        </div>
        <div class="flex items-center gap-4">
            <button id="loginBtn" class="text-xs font-bold bg-white/5 border border-white/10 px-5 py-2.5 rounded-full hover:bg-amber-500 hover:text-black transition-all">
                ADMIN LOGIN
            </button>
        </div>
    </header>

    <main class="max-w-5xl mx-auto p-4 md:p-10 space-y-12">
        
        <section id="adminPanel" class="hidden">
            <div class="p-8 rounded-[2.5rem] border-2 border-amber-500/30 bg-amber-500/5 shadow-[0_0_50px_-12px_rgba(245,158,11,0.2)]">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h2 class="text-amber-500 font-black uppercase tracking-widest text-lg">Broadcaster Hub</h2>
                        <p id="broadcastInfo" class="text-gray-400 text-xs italic">Setup your camera for the finals</p>
                    </div>
                    <button class="px-4 py-2 bg-red-600/20 text-red-500 rounded-xl text-[10px] font-black border border-red-500/20 hover:bg-red-600 hover:text-white transition">
                        LOGOUT
                    </button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="relative aspect-video bg-black rounded-3xl overflow-hidden border border-gray-800 shadow-inner">
                        <div id="local-player" class="w-full h-full object-cover"></div>
                        <div class="absolute top-4 left-4 bg-black/80 px-3 py-1 rounded text-[10px] font-bold text-amber-500 border border-amber-500/30">PREVIEW</div>
                    </div>

                    <div class="flex flex-col justify-center space-y-4">
                        <button id="streamToggleBtn" class="bg-gradient-to-br from-amber-400 to-amber-600 text-black font-black py-6 rounded-2xl shadow-xl uppercase tracking-tighter text-xl active:scale-95 transition-transform">
                            Go Live to School
                        </button>
                        <button id="pushAlertBtn" class="bg-white/10 hover:bg-white/20 py-4 rounded-2xl font-bold border border-white/10 transition-colors text-sm">
                            📢 Notify All Users: "GAME BEGUN!"
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <div class="relative group">
            <div class="bg-white/5 backdrop-blur-xl rounded-[3rem] overflow-hidden border border-white/10 shadow-2xl">
                
                <div id="player-stage" class="aspect-video bg-black flex flex-col items-center justify-center text-center p-6 relative">
                    
                    <div id="standby-ui" class="z-10">
                        <div class="mb-6 text-amber-500/20">
                            <svg class="w-24 h-24 mx-auto animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <h2 class="text-4xl font-black italic tracking-tighter mb-2">WE ARE CONNECTING...</h2>
                        <p class="text-gray-500 font-medium max-w-xs mx-auto text-sm">Standby for the Elite League finals. Broadcast will begin as soon as the admin is live.</p>
                    </div>

                    <div id="remote-player" class="absolute inset-0 w-full h-full bg-black"></div>
                    
                    <div id="live-tag" class="absolute top-8 left-8 hidden flex items-center gap-2 bg-red-600 px-4 py-2 rounded-full z-20 shadow-lg">
                        <div class="w-2 h-2 bg-white rounded-full animate-ping"></div>
                        <span class="text-[10px] font-black uppercase tracking-widest">Live Finals</span>
                    </div>
                </div>

                <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-5 bg-black/40 border-t border-white/5">
                    <button id="btn-admin1" class="p-6 rounded-[2rem] border-2 border-amber-500 bg-amber-500/10 flex justify-between items-center transition-all hover:scale-[1.02] active:scale-95">
                        <div class="text-left">
                            <p class="text-[10px] uppercase text-amber-500 font-black tracking-widest mb-1">Stream 01</p>
                            <p class="text-lg font-bold uppercase italic">Main Court Feed</p>
                        </div>
                        <div class="bg-amber-500 text-black p-2.5 rounded-2xl shadow-lg">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
                        </div>
                    </button>

                    <button id="btn-admin2" class="p-6 rounded-[2rem] border border-white/10 bg-white/5 flex justify-between items-center transition-all opacity-40 hover:opacity-100 active:scale-95 grayscale hover:grayscale-0">
                        <div class="text-left">
                            <p class="text-[10px] uppercase text-gray-500 font-black tracking-widest mb-1">Stream 02</p>
                            <p class="text-lg font-bold uppercase italic text-gray-400">Side View / Crowd</p>
                        </div>
                        <div class="bg-gray-800 text-gray-500 p-2.5 rounded-2xl">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.366zM14.89 13.477L6.524 5.11a6 6 0 018.366 8.367z" clip-rule="evenodd"/></svg>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Admin PIN Modal -->
    <div id="pinModal" class="fixed inset-0 flex items-center justify-center bg-black/95 z-[100] hidden p-4">
        <div class="bg-[#0f0f0f] p-10 rounded-[3rem] border border-white/10 w-full max-w-sm text-center shadow-2xl transition-all scale-100">
            <div class="w-20 h-20 bg-amber-500/10 text-amber-500 rounded-full flex items-center justify-center mx-auto mb-8 border border-amber-500/20">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <h3 class="text-2xl font-black mb-2 uppercase tracking-tighter">Admin Login</h3>
            <p class="text-gray-500 text-sm mb-8 leading-relaxed font-medium">Enter your secure 4-digit PIN to access broadcaster controls.</p>
            <input type="password" id="pinInput" maxlength="4" placeholder="••••" class="w-full bg-black border border-white/10 p-5 rounded-2xl text-center text-4xl tracking-[0.5em] mb-8 outline-none focus:border-amber-500 text-amber-500 transition-all placeholder:text-gray-800">
            <button id="submitPin" class="w-full bg-gradient-to-r from-amber-400 to-amber-600 text-black font-black py-5 rounded-2xl shadow-xl active:scale-95 transition-transform text-lg uppercase tracking-widest">
                Access Panel
            </button>
            <button id="closePin" class="mt-8 text-gray-600 text-xs font-bold uppercase tracking-widest hover:text-white transition-colors">Cancel</button>
        </div>
    </div>

    <!-- Alert Modal -->
    <div id="alertModal" class="fixed inset-0 flex items-center justify-center bg-black/90 z-[100] hidden p-4">
        <div class="bg-white text-black p-12 rounded-[3.5rem] w-full max-w-sm text-center shadow-[0_0_80px_rgba(255,255,255,0.1)] transition-all">
            <div class="w-24 h-24 bg-red-50 text-red-600 rounded-full flex items-center justify-center mx-auto mb-8 border border-red-100">
                <svg class="w-12 h-12 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 id="alertTitle" class="text-3xl font-black mb-3 uppercase tracking-tighter">Stream Paused</h3>
            <p id="alertMsg" class="text-gray-600 mb-10 font-medium leading-relaxed">The broadcaster has temporarily disconnected. Please wait for reconnection.</p>
            <button id="closeAlert" class="w-full bg-black text-white font-black py-6 rounded-3xl shadow-2xl hover:bg-gray-800 transition-colors uppercase tracking-widest text-sm">
                Return to Viewer
            </button>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.9.0/firebase-app.js";
        import { getDatabase, ref, set, onValue } from "https://www.gstatic.com/firebasejs/12.9.0/firebase-database.js";

        // 1. FIREBASE INIT
        const firebaseConfig = {
            apiKey: "AIzaSyDsxf_2FkvyfU2QQsd_DBytd9pPi6r4o0k",
            authDomain: "learning-pro-f756e.firebaseapp.com",
            projectId: "learning-pro-f756e",
            storageBucket: "learning-pro-f756e.firebasestorage.app",
            messagingSenderId: "410163553623",
            appId: "1:410163553623:web:10fceb9616086fe9640a12",
            measurementId: "G-RXKDXG4J84"
        };

        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app);

        // 2. CONFIG
        const AGORA_APP_ID = "6b0b36a41dae4815b0d440836a4fb1f6";
        const CHANNEL = "EliteLeagueFinals";
        const ADMIN_PIN = "2026";

        let client = AgoraRTC.createClient({ mode: "live", codec: "vp8" });
        let localTracks = { videoTrack: null, audioTrack: null };
        let isStreaming = false;

        // 3. MODAL HELPERS
        window.openModal = (id) => {
            const modal = document.getElementById(id);
            if (modal) modal.classList.remove('hidden');
        };

        window.closeModal = (id) => {
            const modal = document.getElementById(id);
            if (modal) modal.classList.add('hidden');
        };

        // 4. ADMIN LOGIN
        window.verifyAdmin = () => {
            const pin = document.getElementById('pinInput').value;
            if (pin === ADMIN_PIN) {
                closeModal('pinModal');
                document.getElementById('adminPanel').classList.remove('hidden');
                document.getElementById('loginBtn').innerText = "DASHBOARD";
                document.getElementById('loginBtn').classList.add('bg-amber-500', 'text-black');
            } else {
                alert("ACCESS DENIED: PIN incorrect.");
                document.getElementById('pinInput').value = "";
            }
        };

        // 5. TOGGLE STREAM (Broadcaster)
        window.toggleStream = async () => {
            const btn = document.getElementById('streamToggleBtn');

            if (!isStreaming) {
                try {
                    // IMPORTANT: Set role BEFORE join
                    client.setClientRole("host");
                    await client.join(AGORA_APP_ID, CHANNEL, null, null);

                    localTracks.audioTrack = await AgoraRTC.createMicrophoneAudioTrack();
                    localTracks.videoTrack = await AgoraRTC.createCameraVideoTrack({
                        encoderConfig: "720p_1"
                    });

                    localTracks.videoTrack.play("local-player");
                    await client.publish(Object.values(localTracks));

                    isStreaming = true;
                    btn.innerText = "STOP FEED";
                    btn.classList.add('bg-red-600', 'text-white');

                    set(ref(db, 'streamStatus/admin1'), { live: true, lastSeen: Date.now() });

                } catch (e) {
                    console.error("Failed to start stream:", e);
                    alert("Could not start stream: " + (e.message || "Check permissions / network"));
                }
            } else {
                try {
                    await client.unpublish(Object.values(localTracks));
                    localTracks.audioTrack?.close();
                    localTracks.videoTrack?.close();
                    localTracks = { videoTrack: null, audioTrack: null };

                    // Optional: leave channel or switch back to audience
                    // await client.leave();

                    isStreaming = false;
                    btn.innerText = "Go Live to School";
                    btn.classList.remove('bg-red-600', 'text-white');

                    set(ref(db, 'streamStatus/admin1'), { live: false, lastSeen: Date.now() });

                } catch (e) {
                    console.error("Failed to stop stream:", e);
                }
            }
        };

        // 6. PUSH GLOBAL ALERT
        window.sendPushAlert = () => {
            set(ref(db, 'globalAlert'), {
                title: "GAME BEGAN! 🏆",
                message: "The Elite League Finals are live. Join the stream now!",
                timestamp: Date.now()
            });
        };

        // Listen for alerts (all clients)
        onValue(ref(db, 'globalAlert'), (snapshot) => {
            const data = snapshot.val();
            if (data && (Date.now() - data.timestamp < 15000)) {
                document.getElementById('alertTitle').innerText = data.title;
                document.getElementById('alertMsg').innerText = data.message;
                openModal('alertModal');

                if (Notification.permission === "granted") {
                    new Notification(data.title, { body: data.message });
                }
            }
        });

        // 7. VIEWER MODE
        async function startViewer() {
            try {
                // Set role BEFORE join
                client.setClientRole("audience");
                await client.join(AGORA_APP_ID, CHANNEL, null, null);

                client.on("user-published", async (user, mediaType) => {
                    await client.subscribe(user, mediaType);

                    if (mediaType === "video") {
                        document.getElementById('standby-ui').classList.add('hidden');
                        document.getElementById('statusIndicator').classList.add('bg-red-600');
                        document.getElementById('live-tag').classList.remove('hidden');
                        user.videoTrack.play("remote-player");
                    }
                    if (mediaType === "audio") {
                        user.audioTrack.play();
                    }
                });

                client.on("user-unpublished", () => {
                    document.getElementById('standby-ui').classList.remove('hidden');
                    document.getElementById('statusIndicator').classList.remove('bg-red-600');
                    document.getElementById('live-tag').classList.add('hidden');

                    document.getElementById('alertTitle').innerText = "Stream Paused";
                    document.getElementById('alertMsg').innerText = "The admin has disconnected. Please wait for reconnection.";
                    openModal('alertModal');
                });

            } catch (e) {
                console.warn("Viewer join failed:", e);
            }
        }

        // 8. INIT
        window.onload = () => {
            startViewer();

            // Button bindings
            document.getElementById('submitPin')?.addEventListener('click', verifyAdmin);
            document.getElementById('pushAlertBtn')?.addEventListener('click', sendPushAlert);
            document.getElementById('streamToggleBtn')?.addEventListener('click', toggleStream);
            document.getElementById('closeAlert')?.addEventListener('click', () => closeModal('alertModal'));
            document.getElementById('closePin')?.addEventListener('click', () => closeModal('pinModal'));

            // Notifications permission
            if ("Notification" in window && Notification.permission !== "granted") {
                Notification.requestPermission();
            }

            // Catch Agora errors globally
            client.on("error", (err) => {
                console.error("Agora error:", err);
            });
        };
    </script>
</body>
</html>